[configuration]
entry_symbol = "skill_tracker_library_init"
compatibility_minimum = 4.2

[libraries]
macos.debug.arm64 = "res://bin/libskilltracker.macos.template_debug.arm64.dylib"
macos.release.arm64 = "res://bin/libskilltracker.macos.template_release.arm64.dylib"

web.debug.wasm32 = "res://bin/libskilltracker.web.template_debug.wasm32.wasm"
web.release.wasm32 = "res://bin/libskilltracker.web.template_release.wasm32.wasm"